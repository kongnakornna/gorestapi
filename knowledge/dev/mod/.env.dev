COMPOSE_ENV_FILE=.env.dev

SERVER_APP_VERSION=v0.0.1
SERVER_PORT=8088
SERVER_MODE=Development
SERVER_PROCESS_TIMEOUT=60
SERVER_READ_TIMEOUT=5
SERVER_WRITE_TIMEOUT=5

LOGGER_ENCODING=console
LOGGER_LEVEL=debug

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DBNAME=db

# ========== Monitoring Configuration ==========
MONITORING_ENABLED=false
METRICS_ENABLED=true
TRACING_ENABLED=true
SENTRY_ENABLED=true
SYSTEM_METRICS_ENABLED=true
ALERT_ENABLED=false

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Jaeger
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Email Alert (SMTP)
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=465
ALERT_SMTP_USER=your-email@gmail.com
ALERT_SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=alert@icmongolang.com
ALERT_TO_EMAIL=admin@icmongolang.com

